<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8"> 
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StageAlternance - trouver votre opportunité</title>
    <link rel="stylesheet" href="/public/css/style.css"> 
    <link rel="stylesheet" href="/public/css/offres.css">
</head>
<body> 		
	<header>
		<nav class="navbar">
			<div class="logo">
				<div class="logo-image">
					<svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="currentColor" viewBox="0 0 16 16">
            					<path d="M5 2a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2h3.5A1.5 1.5 0 0 1 16 3.5v9a1.5 1.5 0 0 1-1.5 1.5H14a.5.5 0 0 1-1 0H3a.5.5 0 0 1-1 0h-.5A1.5 1.5 0 0 1 0 12.5v-9A1.5 1.5 0 0 1 1.5 2zm1 0h4a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1M1.5 3a.5.5 0 0 0-.5.5v9a.5.5 0 0 0 .5.5H3V3zM15 12.5v-9a.5.5 0 0 0-.5-.5H13v10h1.5a.5.5 0 0 0 .5-.5m-3 .5V3H4v10z"/>
        				</svg>
				</div>
				<div class="logo-text">StageAlternance</div>
			</div>
			<div class="nav-links">
				<div class="nav-icone"><a href="/">Accueil</a></div>
				<div class="nav-icone"><a href="/offres">Offres</a></div>
				<div class="nav-icone"><a href="/entreprises">Entreprises</a></div>
				<div><a href="/candidat" class="nav-btn"><span>Candidat</span></a></div>
			</div>
		</nav>
	</header>

	<main>
	{#Pour la barre de recherche#} 
	<div class="barre-recherche">
            <span class="champ-recherche">
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
            			<path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
        		</svg>
               	 	<input type="text" placeholder="Intitulé du poste...">
            </span>
            <span class="champ-recherche">
		<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
            		<path d="M5 2a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2h3.5A1.5 1.5 0 0 1 16 3.5v9a1.5 1.5 0 0 1-1.5 1.5H14a.5.5 0 0 1-1 0H3a.5.5 0 0 1-1 0h-.5A1.5 1.5 0 0 1 0 12.5v-9A1.5 1.5 0 0 1 1.5 2zm1 0h4a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1M1.5 3a.5.5 0 0 0-.5.5v9a.5.5 0 0 0 .5.5H3V3zM15 12.5v-9a.5.5 0 0 0-.5-.5H13v10h1.5a.5.5 0 0 0 .5-.5m-3 .5V3H4v10z"/>
        	</svg>
                <select>
                    <option value="">Type de contrat</option>
                    <option value="stage">Stage</option>
                    <option value="alternance">Alternance</option>
                </select>
            </span>
            <span class="champ-recherche">
		<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
            		<path d="M12.166 8.94c-.524 1.062-1.234 2.12-1.96 3.07A32 32 0 0 1 8 14.58a32 32 0 0 1-2.206-2.57c-.726-.95-1.436-2.008-1.96-3.07C3.304 7.867 3 6.862 3 6a5 5 0 0 1 10 0c0 .862-.305 1.867-.834 2.94M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10"/>
            		<path d="M8 8a2 2 0 1 1 0-4 2 2 0 0 1 0 4m0 1a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
        	</svg>
                <input type="text" placeholder="Ville...">
            </span>
            <button class="btn-rechercher">Rechercher</button>
        </div>

        {# Bouton filtres#}
        <div class="filtres-bar">
            <button class="btn-filtres" id="btn-filtres">
		<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
        		<path fill-rule="evenodd" d="M11.5 2a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3M9.05 3a2.5 2.5 0 0 1 4.9 0H16v1h-2.05a2.5 2.5 0 0 1-4.9 0H0V3zM4.5 7a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3M2.05 8a2.5 2.5 0 0 1 4.9 0H16v1H6.95a2.5 2.5 0 0 1-4.9 0H0V8zm9.45 4a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3m-2.45 1a2.5 2.5 0 0 1 4.9 0H16v1h-2.05a2.5 2.5 0 0 1-4.9 0H0v-1z"/>
    		</svg>
		Tous les filtres 
	    </button>
        </div>

        <section class="liste-offres">
            <div class="liste-header">
                <h2>Offres de stage disponibles</h2>
                <div class="liste-controls">
                    {# Twig affiche les variables avec {{ }} #}
                    <span class="compteur">{{ total_offres }} offres trouvées</span>
                    <select class="tri-offres">
                        <option value="recent">Plus récentes</option>
                        <option value="pertinence">Pertinence</option>
                        <option value="remuneration">Rémunération</option>
                    </select>
                </div>
            </div>

           {# Boucle Twig pour afficher les cartes#}
            {% for offre in offres %}
            <article class="carte-offre">
                <div class="carte-header">
                    <h3>{{ offre.titre }}</h3>
                    <span class="tag-contrat">{{ offre.contrat }}</span>
                </div>
		<div class="carte-infos">
    			<span class="info-item">
        			<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
           				 <path d="M12.166 8.94c-.524 1.062-1.234 2.12-1.96 3.07A32 32 0 0 1 8 14.58a32 32 0 0 1-2.206-2.57c-.726-.95-1.436-2.008-1.96-3.07C3.304 7.867 3 6.862 3 6a5 5 0 0 1 10 0c0 .862-.305 1.867-.834 2.94M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10"/>
           				 <path d="M8 8a2 2 0 1 1 0-4 2 2 0 0 1 0 4m0 1a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
        			</svg>
        			{{ offre.ville }}
    			</span>
    			<span class="info-item">
        			<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
            				<path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71z"/>
            				<path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0"/>
        			</svg>
        			{{ offre.duree }}
    			</span>
    			<span class="info-item">
        			<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
            				<path d="M8 10a2 2 0 1 0 0-4 2 2 0 0 0 0 4"/>
            				<path d="M0 4a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1zm3 0a2 2 0 0 1-2 2v4a2 2 0 0 1 2 2h10a2 2 0 0 1 2-2V6a2 2 0 0 1-2-2z"/>
        			</svg>
       			 	{{ offre.remuneration }}
    			</span>
		</div>               
                <div class="competences">
                   {# Boucle dans la boucle pour les compétences#}                    {% for competence in offre.competences %}
                        <span class="competences">{{ competence }}</span>
                    {% endfor %}
                </div>
                <div class="carte-footer">
                    <span class="nb-candidatures">
                        {{ offre.candidatures }} candidatures · Publié le {{ offre.date }}
                    </span>
                    <button class="details-btn">Voir les détails</button>
                </div>
            </article>
            {% endfor %}

           {#Pour la pagination#}
            <div class="pagination">
                {% if page_actuelle > 1 %}
                    <a href="?page={{ page_actuelle - 1 }}" class="page-btn">← Précédent</a>
                {% endif %}

                {% for i in 1..total_pages %}
                    <a href="?page={{ i }}" 
                       class="page-btn {{ i == page_actuelle ? 'active' : '' }}">
                        {{ i }}
                    </a>
                {% endfor %}

                {% if page_actuelle < total_pages %}
                    <a href="?page={{ page_actuelle + 1 }}" class="page-btn">Suivant →</a>
                {% endif %}
            </div>

        </section>
    </main>

    <footer>
        <div class="footer-content">
            <div>
                <h2>StageAlternance</h2>
                <p>Plateforme de recherche de stage pour tous les étudiants</p>
            </div>
            <div>
                <h2>Liens rapides</h2>
                <div class="footer-links"><a href="/offres">Offres de stage</a></div>
                <div class="footer-links"><a href="/entreprises">Entreprises</a></div>
            </div>
            <div>
                <h2>Contact</h2>
                <div class="footer-info"><a href="mailto:contact@stagealternance.fr">contact@stagealternance.fr</a></div>
            </div>
        </div>
        <div class="barre"></div>
        <div class="copyright">© 2026 StageAlternance. Tous droits réservés.</div>
    </footer>

    <script src="/public/js/offres.js"></script>
</body>
</html>
